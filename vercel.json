{
  "buildCommand": "npm run build",
  "outputDirectory": ".output",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/server/index.js"
    }
  ],
  "functions": {
    ".output/server/index.js": {
      "runtime": "nodejs20.x"
    }
  }
}
